{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ari Configuration",
  "description": "Configuration for Ari CLI - AI-assisted development",
  "type": "object",
  "properties": {
    "router": {
      "type": "object",
      "description": "Model routing and selection settings",
      "properties": {
        "strategy": {
          "type": "string",
          "description": "How to select models: balanced (default), speed, quality, or cost",
          "enum": ["balanced", "speed", "quality", "cost"],
          "default": "balanced"
        },
        "daily_budget": {
          "type": "number",
          "description": "Maximum daily spend in USD (0 = unlimited)",
          "default": 10.00,
          "minimum": 0
        }
      }
    },
    "models": {
      "type": "object",
      "description": "Model preferences for different task types",
      "properties": {
        "default": {
          "type": "string",
          "description": "Default model for most tasks",
          "default": "openai/gpt-4o"
        },
        "edits": {
          "type": "string",
          "description": "Model for quick edits and small changes",
          "default": "openai/gpt-4o-mini"
        },
        "review": {
          "type": "string",
          "description": "Model for code review and analysis",
          "default": "anthropic/claude-opus-4-5"
        }
      }
    },
    "providers": {
      "type": "object",
      "description": "API provider configurations (advanced)",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "base_url": { "type": "string" },
          "api_key_env": { "type": "string" }
        }
      }
    }
  }
}